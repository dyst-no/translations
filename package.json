{
  "name": "@dyst-no/translations",
  "version": "0.1.4",
  "description": "TypeScript-first translations for server, React, and React Native.",
  "keywords": [
    "i18n",
    "translations",
    "typescript",
    "react",
    "react-native",
    "zod"
  ],
  "homepage": "https://github.com/dyst-no/translations#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dyst-no/translations.git"
  },
  "bugs": {
    "url": "https://github.com/dyst-no/translations/issues"
  },
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core.mjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react.mjs"
    },
    "./platforms/react": {
      "types": "./dist/platforms/react/index.d.ts",
      "import": "./dist/platforms/react.mjs"
    },
    "./platforms/react-native": {
      "types": "./dist/platforms/react-native/index.d.ts",
      "import": "./dist/platforms/react-native.mjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server.mjs"
    },
    "./zod": {
      "types": "./dist/zod/index.d.ts",
      "import": "./dist/zod.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown && tsc -p tsconfig.build.json",
    "format": "biome check --write --error-on-warnings .",
    "typecheck": "tsc --pretty false --noEmit",
    "test": "bun run typecheck && bun test",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "prepublishOnly": "bun run build && bun run test"
  },
  "peerDependenciesMeta": {
    "expo-localization": {
      "optional": true
    },
    "expo-sqlite": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "expo-localization": "^16.0.1",
    "expo-sqlite": "^15.2.14",
    "react-native": "^0.79.5",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@happy-dom/global-registrator": "^20.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "expo-localization": "^16.0.1",
    "expo-sqlite": "^15.2.14",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "zod": "^4.3.5"
  }
}
